# Version control and CI — not needed at image build time
.git
.github
.devcontainer

# Generated output
*.pdf
*.html
*.zip

# LaTeX intermediate files
*.aux
*.log
*.out
*.toc

# Cached installers from local builds
*.deb
*.tar.xz

# User proposals — workspace is mounted at runtime, not baked in
proposals/

# Node and Python
# package.json is included (Dockerfile COPYs it to install npm tools with overrides)
node_modules
package-lock.json
__pycache__

# Documentation, agent prompts, and dev tooling — not needed at image build time
README.md
docs/
prompts/
# Development-only files — not needed for the document build pipeline.
# Elicitation scripts, prompts, and docs are for development and CI workflows.
scripts/
