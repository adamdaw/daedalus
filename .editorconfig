root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_style = space
indent_size = 2
# Trailing spaces are meaningful in some Markdown renderers; leave them alone
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.yaml]
indent_style = space
indent_size = 2

[*.tex]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2
