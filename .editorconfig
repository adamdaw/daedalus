root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_style = space
indent_size = 2
# Trailing spaces are meaningful in some Markdown renderers; leave them alone
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.yaml]
indent_style = space
indent_size = 2

[*.tex]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

# Shell scripts — Google Shell Style Guide recommends 2-space indent
# Reference: https://google.github.io/styleguide/shellguide.html#s5.1-indentation
[*.sh]
indent_style = space
indent_size = 2

# bats test files follow the same convention as shell scripts
[*.bats]
indent_style = space
indent_size = 2

# PEP 8 — https://peps.python.org/pep-0008/#indentation
[*.py]
indent_style = space
indent_size = 4

# Lua — lua.org conventions
[*.lua]
indent_style = space
indent_size = 2
